{
    "name": "@codenautic/ui",
    "version": "0.0.0",
    "description": "Frontend — Vite + TanStack Router SPA dashboard for CodeNautic",
    "private": true,
    "type": "module",
    "scripts": {
        "build:analyze": "bun run codegen && vite build --mode analyze",
        "build": "bun run codegen && vite build",
        "build-storybook": "storybook build",
        "clean": "rm -rf dist coverage",
        "codegen": "openapi-typescript openapi/schema.yaml -o src/lib/api/generated/index.ts",
        "codegen:check": "openapi-typescript openapi/schema.yaml -o src/lib/api/generated/index.ts --check",
        "dev": "bun run codegen && vite",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "lint": "eslint . --fix",
        "perf:check": "bun run build:analyze && bun ./scripts/check-performance-budgets.mjs",
        "preview": "vite preview",
        "storybook": "bun ./scripts/run-storybook.mjs",
        "test": "vitest run",
        "test:coverage": "vitest run --no-file-parallelism --coverage",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "@dagrejs/dagre": "^2.0.4",
        "@heroui/react": "^3.0.0-beta.7",
        "@heroui/styles": "^3.0.0-beta.7",
        "@hookform/resolvers": "^5.2.2",
        "@react-three/drei": "^10.7.7",
        "@react-three/fiber": "^9.5.0",
        "@sentry/react": "^10.39.0",
        "@tanstack/react-query": "^5.90.21",
        "@tanstack/react-router": "^1.161.1",
        "@tanstack/react-table": "^8.21.3",
        "@tanstack/react-virtual": "^3.13.18",
        "@tanstack/router-devtools": "^1.161.1",
        "@xyflow/react": "^12.10.1",
        "geist": "^1.7.0",
        "i18next": "^25.8.11",
        "i18next-browser-languagedetector": "^8.2.1",
        "isomorphic-dompurify": "^2.36.0",
        "lucide-react": "^0.570.0",
        "motion": "^12.34.2",
        "postcss": "^8.5.6",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "react-hook-form": "^7.71.1",
        "react-i18next": "^16.5.4",
        "react-markdown": "^10.1.0",
        "recharts": "^3.7.0",
        "shiki": "^3.22.0",
        "three": "^0.183.1",
        "tw-animate-css": "^1.4.0",
        "web-vitals": "^5.1.0",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@eslint/js": "^9.20.0",
        "@sentry/vite-plugin": "^4.9.1",
        "@storybook/addon-a11y": "8",
        "@storybook/addon-essentials": "8",
        "@storybook/addon-themes": "8",
        "@storybook/blocks": "8",
        "@storybook/react": "8",
        "@storybook/react-vite": "8",
        "@tailwindcss/postcss": "^4.0.0",
        "@tanstack/react-query-devtools": "^5.91.3",
        "@tanstack/router-plugin": "^1.161.1",
        "@testing-library/dom": "^10.4.1",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/node": "25.2.3",
        "@types/react": "^19.0.0",
        "@types/react-dom": "^19.0.0",
        "@types/three": "^0.183.0",
        "@vitejs/plugin-react": "^5.1.4",
        "@vitejs/plugin-react-swc": "^4.2.3",
        "@vitest/coverage-v8": "^4.0.18",
        "eslint": "^9.20.0",
        "happy-dom": "^20.6.1",
        "msw": "^2.12.10",
        "openapi-typescript": "^7.13.0",
        "prettier": "^3.5.0",
        "rollup-plugin-visualizer": "^7.0.0",
        "storybook": "8",
        "tailwindcss": "^4.0.0",
        "typescript": "^5.7.0",
        "typescript-eslint": "^8.24.0",
        "vite": "^7.3.1",
        "vitest": "^4.0.18"
    },
    "license": "MIT",
    "msw": {
        "workerDirectory": [
            "public"
        ]
    }
}
