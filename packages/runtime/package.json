{
  "name": "@codenautic/runtime",
  "version": "0.0.0",
  "description": "Server — API (NestJS), Webhooks, Workers (Review, Scan, Agent, Notification, Analytics), Scheduler, MCP",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "clean": "rm -rf dist",
    "dev:api": "bun --watch src/api/main.ts",
    "dev:webhooks": "bun --watch src/webhooks/main.ts",
    "start:api": "bun src/api/main.ts",
    "start:webhooks": "bun src/webhooks/main.ts",
    "start:review-worker": "bun src/review-worker/main.ts",
    "start:scan-worker": "bun src/scan-worker/main.ts",
    "start:agent-worker": "bun src/agent-worker/main.ts",
    "start:notification-worker": "bun src/notification-worker/main.ts",
    "start:analytics-worker": "bun src/analytics-worker/main.ts",
    "start:scheduler": "bun src/scheduler/main.ts",
    "start:mcp": "bun src/mcp/main.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "migrate:seed": "bun src/api/migrations/seed.ts"
  },
  "dependencies": {
    "@codenautic/core": "workspace:*",
    "@codenautic/adapters": "workspace:*",
    "@casl/ability": "^6.8.0",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/mongoose": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/terminus": "^11.0.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.69.0",
    "@opentelemetry/exporter-prometheus": "^0.212.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.212.0",
    "@opentelemetry/resources": "^2.5.1",
    "@opentelemetry/sdk-metrics": "^2.5.1",
    "@opentelemetry/sdk-node": "^0.212.0",
    "@opentelemetry/sdk-trace-node": "^2.5.1",
    "@opentelemetry/semantic-conventions": "^1.39.0",
    "@pyroscope/nodejs": "^0.4.10",
    "@qdrant/js-client-rest": "^1.16.2",
    "@segment/analytics-node": "^2.3.0",
    "@sentry/node": "^10.39.0",
    "@sentry/opentelemetry": "^10.39.0",
    "bullmq": "^5.69.3",
    "helmet": "^8.0.0",
    "ioredis": "^5.9.3",
    "jose": "^6.1.3",
    "mongoose": "^9.2.1",
    "node-cron": "^3.0.3",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "posthog-node": "^5.24.17",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "@nestjs/testing": "^11.0.0",
    "@types/bun": "^1.2.0",
    "@types/express": "^5.0.0",
    "@types/node-cron": "^3.0.11",
    "eslint": "^9.20.0",
    "mongodb-memory-server": "^10.1.0",
    "prettier": "^3.5.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.24.0"
  },
  "license": "MIT"
}
